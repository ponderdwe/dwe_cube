# =============================================================
# DWE Cube — Environment Variables
# Copy to .env and fill in values.
# =============================================================

# ── Redshift (data warehouse) ─────────────────────────────────
CUBEJS_DB_TYPE=redshift
CUBEJS_DB_HOST=your-cluster.redshift.amazonaws.com
CUBEJS_DB_NAME=your_database
CUBEJS_DB_USER=your_user
CUBEJS_DB_PASS=your_password
CUBEJS_DB_PORT=5439
CUBEJS_DB_SSL=true

# ── Cube.js ───────────────────────────────────────────────────
CUBEJS_API_SECRET=change_me_to_random_string
CUBEJS_DEV_MODE=false
CUBEJS_SCHEDULED_REFRESH=true
CUBEJS_SCHEDULED_REFRESH_DEFAULT=true
CUBEJS_SQL_PASSWORD=change_me_to_random_string
NODE_ENV=production

# ── DBT Cloud ─────────────────────────────────────────────────
DBT_CLOUD_TOKEN=
DBT_CLOUD_ACCOUNTID=
DBT_CLOUD_JOB_ID=

# ── Superset integration ──────────────────────────────────────
SUPERSET_URL=https://superset.example.com
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=

# ── AWS (for Bedrock LLM) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
LLM_MODEL_ID=bedrock:anthropic.claude-sonnet-4-20250514-v1:0

# ── RAG / Vector DB ───────────────────────────────────────────
MILVUS_SERVER_URI=http://milvus-standalone:19530
CUBE_API_URL=http://cube_api:4000/cubejs-api/v1
CUBE_URL=http://cube_api:4000
FASTAPI_URL=http://fastapi:8080

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=change_me_to_random_string
FAST_API_ACCESS_SECRET_TOKEN=change_me_to_random_string
STREAMLIT_PASSWORD=change_me_to_random_string

# ── DBT → Cube sync (full Redshift URI) ───────────────────────
DATABASE_URI=redshift+psycopg2://your_user:your_password@your-cluster.redshift.amazonaws.com:5439/your_database
